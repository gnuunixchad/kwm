        .{ .app_id = .{ .str = "virt-manager" }, .scroller_mfact = 0.85 },
        .{ .app_id = .{ .str = "footclient" }, .is_terminal = true, .scroller_mfact = 0.5 },
        .{ .app_id = .{ .str = "swayimg" }, .is_terminal = true },
        .{ .app_id = .{ .str = "mpv" }, .floating = false },
    },
    .input_device_rules = .{
        .{ .repeat_info = .{ .rate = 30, .delay = 200 } },
    },
    .libinput_device_rules = .{
        .{ .name = .{ .str = ".*[tT]ouchpad", .regex = true }, .tap = .enabled, .drag = .enabled, .natural_scroll = .enabled },
        .{ .tap = .enabled, .drag = .enabled }
    },
    .xkb_keyboard_rules = .{
        //
    },
}
