Date: Thu, 26 Mar 2026 16:23:31 +0800
Subject: [PATCH] reduce tags padding

---
 src/kwm/bar.zig | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/kwm/bar.zig b/src/kwm/bar.zig
index 57ab7ea..388c4c5 100644
--- a/src/kwm/bar.zig
+++ b/src/kwm/bar.zig
@@ -243,7 +243,7 @@ inline fn static_component_width(self: *Self) i32 {
 
 
 inline fn get_pad(self: *const Self) u16 {
-    return @intCast(self.font.height);
+    return @intCast(@divFloor(self.font.height * 3, 4)); // reduce padding to 3/4
 }
 
 
